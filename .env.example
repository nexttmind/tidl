# PrescribeRx Sandbox (token rotates every ~12h — see prescribe-rx-sandbox-tokens.md)
PRX_API_BASE_URL=https://demo.prescribe-rx.com/api/v1

# Single API token from PRX sandbox (format: {id}|{secret}) — server only, never in browser
PRX_API_TOKEN=

# Unified intake (POST /telehealth/intake/unified) — Flow 1 from PRX docs
PRX_ENCOUNTER_TYPE_SLUG=glp-1-screening
PRX_GLP1_PRODUCT_TYPE_SLUG=tirzepatide

# Set to false in production; auto-detected on demo.prescribe-rx.com
PRX_SANDBOX=true

# Checkout flags in src/lib/pricing.ts:
#   CHECKOUT_DEMO_ZERO (currently false) — when true, due-today and the unified
#     intake payment.amount are $0. When false, we record the curated order total.
#   CHECKOUT_SANDBOX (currently true) — keeps the prefilled sandbox test card and
#     "no real charge" copy; payment always posts as mode: reference_captured.

# Webhook signature verification (from PRX admin → Webhooks, when available)
PRX_WEBHOOK_SECRET=

# Optional: public base URL if a client-side helper needs the host (no secrets)
VITE_PRX_API_BASE_URL=https://demo.prescribe-rx.com/api/v1

# --- Marketing attribution (client-safe IDs only) ---
# Google Tag Manager container, e.g. GTM-XXXXXXX
VITE_GTM_ID=
# Meta (Facebook) Pixel numeric ID
VITE_META_PIXEL_ID=
# Set true in local dev to load tags + funnel events without production build
VITE_ANALYTICS_DEBUG=false

# --- Optional: only if PRX issues separate production tokens later ---
# PRX_TOKEN_CLIENT=
# PRX_TOKEN_PATIENT=
# PRX_TOKEN_PROVIDER=
# PRX_TOKEN_SALES_ORG=
